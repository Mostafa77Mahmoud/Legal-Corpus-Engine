# Copy this file to .env and fill in your values.

# Required: Gemini API keys (comma-separated, no spaces)
# Provide multiple keys to enable automatic rotation on quota exhaustion.
# Example with 3 keys:
# GEMINI_API_KEYS=AIzaSy...key1,AIzaSy...key2,AIzaSy...key3
GEMINI_API_KEYS=your_gemini_api_key_here

# Optional: Override the default primary model
# PRIMARY_MODEL=gemini-2.0-flash
